# Twilio Credentials
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# AWS SNS Credentials
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_DEFAULT_REGION=us-east-1

# General Configurations
USE_LOCAL_MOCKS=FALSE            # Set to FALSE to send live messages; TRUE to mock them
NOTIFICATION_CHANNEL=BOTH          # SMS, WHATSAPP, or BOTH
ADMIN_PHONE_NUMBER=+919999999999   # Coordinator/Admin phone to receive 0 pool matches fallback request alerts
